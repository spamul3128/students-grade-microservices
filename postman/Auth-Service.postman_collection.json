    {
      "name": "Register New Student",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"username\": \"alice.wonder\",\n  \"email\": \"alice.wonder@school.edu\",\n  \"password\": \"password123\",\n  \"role\": \"Student\"\n}"
        },
